# Blizzard Battle.net 개발자 포털 (https://develop.battle.net/) 에서 발급.
# 이 두 값이 모두 있으면 /api/guild-roster 가 실제 Blizzard Game Data API를 호출합니다.
# 둘 중 하나라도 비어 있으면 자동으로 더미 폴백 모드로 동작합니다.
#
# 로컬: 이 파일을 .env.local 로 복사 후 값을 채워 넣으세요. .env.local 은 .gitignore 대상입니다.
# Vercel: Project Settings > Environment Variables 에서 동일 키를 등록하세요.
BLIZZARD_CLIENT_ID=
BLIZZARD_CLIENT_SECRET=

# 리전 (기본: kr). us/eu/tw 등으로 바꾸려면 BLIZZARD_REGION 만 교체.
BLIZZARD_REGION=kr

# Upstash Redis (또는 Vercel Marketplace Redis) — 길드 로스터/캐릭터 프로필 응답 캐시 저장소.
# 두 키가 모두 비어 있으면 캐시가 비활성화되고 매 요청이 Blizzard API로 직행합니다 (앱은 계속 동작).
# Vercel: Storage > Create Database > Upstash Redis 를 프로젝트에 연결하면 KV_REST_API_* 가 자동 주입됩니다.
# 로컬: https://console.upstash.com/ 에서 무료 DB를 만들고 REST URL/Token 을 복사하세요.
# 두 가지 네이밍을 모두 인식합니다 (KV_REST_API_* 우선, 없으면 UPSTASH_REDIS_REST_*).
KV_REST_API_URL=
KV_REST_API_TOKEN=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
