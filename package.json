{
  "name": "wow-guild-prototype",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/check-blizzard.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "check:blizzard": "node scripts/check-blizzard.mjs",
    "test:smoke": "node --experimental-strip-types --no-warnings scripts/smoke.mts",
    "verify": "npm run typecheck && npm run lint && npm run test:smoke && npm run build"
  },
  "dependencies": {
    "@upstash/redis": "^1.38.0",
    "next": "15.5.15",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "zustand": "5.0.3"
  },
  "devDependencies": {
    "@types/node": "22.10.7",
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3",
    "autoprefixer": "10.4.20",
    "eslint": "9.18.0",
    "eslint-config-next": "15.5.15",
    "postcss": "8.5.1",
    "tailwindcss": "3.4.17",
    "typescript": "5.7.3"
  }
}
